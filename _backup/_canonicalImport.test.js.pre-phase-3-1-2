      try {
        // Call runMultiCallCanonical directly with a substantive homepage
        // context so tryHomepageExtractionFallback's >100-char guard is met.
        // (Going through runCanonicalImportCall would invoke the real
        // prefetchHomepageContext against a fake URL → empty context.)
        const homepageContext = "Title: Acme Corp\nDescription: makers of widgets\nAbout: Founded 2010 in Boise, ID, USA. Tagline: Better Tomorrow.\nProducts: widgets, gadgets, doohickeys.";
