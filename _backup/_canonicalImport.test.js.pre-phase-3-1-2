test("Phase 2.19.9: response_format defaults to json_object (looser than strict, avoids perfect-or-nothing trap)", async () => {
  // Phase 2.2 disabled response_format. Phase 2.10 re-enabled it as strict
  // json_schema, expecting it to "force emission server-side". Empirically
  // (Spread the Love + Adams + Woodstock + MaraNatha 2026-05-09): strict
  // schema does NOT force emission — it only validates IF the model emits.
  // The "model emits 0 text after N tool calls" failure persisted with
  // strict schema fully active.
  //
  // Per Grok-4's review: strict schema + 8 required fields + tools creates
  // a "perfect-or-nothing trap" — the model keeps researching to satisfy
  // ALL required keys, runs out of budget, terminates without emission.
  // The fix is to switch to json_object (looser) which still nudges the
  // model toward JSON emission without the all-or-nothing semantic.
  //
  // Three modes via XAI_RESPONSE_FORMAT_MODE: strict / json_object / off.
  // Phase 2.19.9 default is "json_object".
  const prev = process.env.XAI_RESPONSE_FORMAT_MODE;
  const prevLegacy = process.env.XAI_USE_RESPONSE_FORMAT;
  delete process.env.XAI_RESPONSE_FORMAT_MODE;
  delete process.env.XAI_USE_RESPONSE_FORMAT;

  let capturedPayload = null;
  try {
    await withMockLiveSearch(
      {
        xaiLiveSearchStreaming: async (opts) => {
          capturedPayload = opts;
          return {
            ok: true,
            resp: {
              text: JSON.stringify({
                tagline: "x",
                headquarters_location: "Austin, TX, USA",
                manufacturing_locations: [],
                industries: [],
                product_keywords: "",
                reviews: [],
                location_source_urls: { hq_source_urls: [], mfg_source_urls: [] },
                red_flag: false,
              }),
            },
            diagnostics: { tool_calls_counted: 4 },
          };
        },
      },
      async (mod) => {
        await mod.runCanonicalImportCall({
          company: { company_name: "Acme", url: "https://acme.example.com" },
          sessionId: "test",
          budgetMs: 60_000,
          fieldsToEnrich: ["tagline"],
        });
      }
    );

    assert.ok(capturedPayload, "streaming was invoked");
    assert.ok(
      capturedPayload.response_format,
      "Phase 2.19.9: response_format must be sent by default (json_object mode)"
    );
    assert.equal(
      capturedPayload.response_format.type,
      "json_object",
      "default mode should be json_object (Phase 2.19.9), not strict json_schema"
    );
  } finally {
    if (prev === undefined) delete process.env.XAI_RESPONSE_FORMAT_MODE;
    else process.env.XAI_RESPONSE_FORMAT_MODE = prev;
    if (prevLegacy === undefined) delete process.env.XAI_USE_RESPONSE_FORMAT;
    else process.env.XAI_USE_RESPONSE_FORMAT = prevLegacy;
  }
});

