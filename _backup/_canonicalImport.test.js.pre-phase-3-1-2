test("Phase 3.0.2: all-503 sub-call failures set infrastructure_failure_all_calls flag and skip fallback", async () => {
  // Empirical (SBO + Baker's, 2026-05-10): xAI returned 503 for an ~10s
  // outage. All 3 multi-calls failed with infrastructure error codes
  // (upstream_503_cooldown, upstream_http_503, upstream_unreachable).
  // Phase 3.0.2 detects this and skips the homepage-extraction fallback
  // (which would also fail with the same circuit-breaker error), then
  // returns a diagnostic flag so handler.js can re-enqueue the company.
  await withMockLiveSearch(
    {
      xaiLiveSearchStreaming: async (opts) => {
        const promptText = opts.prompt || "";
        // Core fails with upstream_unreachable
        if (/THIS CALL ONLY\)?: tagline, industries, product_keywords/i.test(promptText)) {
          return { ok: false, error: "upstream_unreachable", error_code: "upstream_unreachable", diagnostics: { tool_calls_counted: 0 } };
        }
        // Locations fails with upstream_http_503
        if (/THIS CALL ONLY\)?: headquarters_location, manufacturing_locations, location_source_urls/i.test(promptText)) {
          return { ok: false, error: "upstream_http_503", error_code: "upstream_http_503", diagnostics: { tool_calls_counted: 0, upstream_http_status: 503 } };
        }
        // Reviews fails with upstream_503_cooldown (circuit breaker open)
        if (/THIS CALL ONLY\)?: reviews/i.test(promptText)) {
          return { ok: false, error: "upstream_503_cooldown", error_code: "upstream_503_cooldown", diagnostics: { tool_calls_counted: 0, circuit_breaker_open: true } };
        }
        // Homepage-extraction fallback — should NOT be invoked when
        // infrastructure_failure_all_calls is true.
        if (/Extract:\s*- tagline/i.test(promptText)) {
          throw new Error("FALLBACK SHOULD NOT FIRE when all calls had infrastructure failures");
        }
        return { ok: false, error: "unknown_prompt" };
      },
    },
    async (mod) => {
      const prev = process.env.XAI_MULTI_CALL_MODE;
      process.env.XAI_MULTI_CALL_MODE = "on";
      try {
        const homepageContext = "Title: Acme Co\nDescription: makers of widgets\nAbout: Founded 2010 in Boise, ID, USA.";
        const result = await mod.runMultiCallCanonical({
          companyName: "Acme",
          websiteUrl: "https://acme.example",
          websiteHost: "acme.example",
          homepageContext,
          conversationId: "co_test_3_0_2",
          model: "grok-4-latest",
          requested: ["tagline", "headquarters_location", "manufacturing_locations", "industries", "product_keywords", "reviews"],
          startedAt: Date.now(),
        });
        assert.equal(result.ok, false, "all 3 calls failed with infrastructure → ok=false");
        assert.equal(
          result.diagnostics.infrastructure_failure_all_calls,
          true,
          "diagnostic flag must be set"
        );
        assert.equal(
          result.diagnostics.fallback_used,
          false,
          "fallback must be skipped when all 3 had infrastructure failure"
        );
        assert.equal(
          result.diagnostics.fallback_skipped_reason,
          "infrastructure_failure_all_calls"
        );
        // All requested fields should be marked as upstream_503_cooldown.
        for (const f of ["tagline", "headquarters_location", "manufacturing_locations", "industries", "product_keywords", "reviews"]) {
          assert.equal(result.errors[f], "upstream_503_cooldown", `errors[${f}] should be upstream_503_cooldown`);
        }
      } finally {
        if (prev === undefined) delete process.env.XAI_MULTI_CALL_MODE;
        else process.env.XAI_MULTI_CALL_MODE = prev;
      }
    }
  );
});

test("Phase 3.0.2: mixed failure (1 infrastructure + 2 model failures) does NOT set the flag — fallback should still fire", async () => {
  // Only set infrastructure_failure_all_calls when ALL 3 had infrastructure
  // error codes. If 1+ calls hit a model-level failure (model_emitted_no_text,
  // upstream_timeout from a grace-period abort), the flag should be false
  // and the existing fallback rescue path should run.
  let fallbackInvoked = false;
  await withMockLiveSearch(
    {
      xaiLiveSearchStreaming: async (opts) => {
        const promptText = opts.prompt || "";
        // Core fails with upstream_http_503 (infrastructure)
        if (/THIS CALL ONLY\)?: tagline, industries, product_keywords/i.test(promptText)) {
          return { ok: false, error: "upstream_http_503", error_code: "upstream_http_503", diagnostics: { tool_calls_counted: 0 } };
        }
        // Locations fails with model_emitted_no_text (NOT infrastructure)
        if (/THIS CALL ONLY\)?: headquarters_location, manufacturing_locations, location_source_urls/i.test(promptText)) {
          return { ok: false, error: "model_emitted_no_text", error_code: "model_emitted_no_text", diagnostics: { tool_calls_counted: 5 } };
        }
        // Reviews fails with upstream_timeout (model timeout, NOT infrastructure)
        if (/THIS CALL ONLY\)?: reviews/i.test(promptText)) {
          return { ok: false, error: "upstream_timeout", error_code: "upstream_timeout", diagnostics: { tool_calls_counted: 5 } };
        }
        // Homepage-extraction fallback — SHOULD fire because not all infra failures
        if (/Extract:\s*- tagline/i.test(promptText)) {
          fallbackInvoked = true;
          return {
            ok: true,
            resp: { text: JSON.stringify({ tagline: "Rescued", headquarters_location: "" }) },
            diagnostics: { tool_calls_counted: 0 },
          };
        }
        return { ok: false, error: "unknown_prompt" };
      },
    },
    async (mod) => {
      const prev = process.env.XAI_MULTI_CALL_MODE;
      process.env.XAI_MULTI_CALL_MODE = "on";
      try {
        // Need >=100 chars to satisfy the fallback's minimum-context guard.
        const homepageContext = "Title: Acme Co\nDescription: makers of high-quality widgets and gadgets\nAbout: Founded 2010 in Boise, ID, USA. Tagline: Better Tomorrow.\nProducts: widgets, gadgets.";
        const result = await mod.runMultiCallCanonical({
          companyName: "Acme",
          websiteUrl: "https://acme.example",
          websiteHost: "acme.example",
          homepageContext,
          conversationId: "co_test_3_0_2_mixed",
          model: "grok-4-latest",
          requested: ["tagline", "headquarters_location", "manufacturing_locations", "industries", "product_keywords", "reviews"],
          startedAt: Date.now(),
        });
        // Mixed failures → not infrastructure-all → fallback should run
        assert.equal(
          result.diagnostics.infrastructure_failure_all_calls,
          false,
          "mixed failure types should NOT set the infrastructure-all flag"
        );
        assert.equal(fallbackInvoked, true, "fallback must fire when not all calls are infra failures");
      } finally {
        if (prev === undefined) delete process.env.XAI_MULTI_CALL_MODE;
        else process.env.XAI_MULTI_CALL_MODE = prev;
      }
    }
  );
});

