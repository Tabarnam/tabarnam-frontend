const DEFAULT_CANONICAL_FIELDS = [
  "tagline",
  "headquarters_location",
  "manufacturing_locations",
  "industries",
  "product_keywords",
  "reviews",
];

/**
 * Build the canonical company-research prompt — modelled on the grok.com v1.1
 * prompt admin uses for manual cleanup, with output framed as JSON.
 *
 * Per-field rules are kept verbatim from the working grok.com prompt — they've
 * been refined in production. Only the trailing output-shape framing changes
 * (JSON object instead of plaintext labels).
 *
 * @param {Object} opts
 * @param {string} opts.companyName
 * @param {string} opts.websiteUrl
 * @param {string[]} [opts.fields] - JSON-key names to populate. Defaults to
 *        the full DEFAULT_CANONICAL_FIELDS list.
 * @param {boolean} [opts.includeSourceUrls=true] - Ask the model to include
 *        location_source_urls inline (used by bulk imports for audit).
 * @returns {string} Prompt body suitable for /v1/responses.
 */
function buildCanonicalImportPrompt({
  companyName,
  websiteUrl,
  fields = DEFAULT_CANONICAL_FIELDS,
  includeSourceUrls = true,
  homepageContext = "",
} = {}) {
  const name = String(companyName || "").trim() || "(unknown company)";
  const url = String(websiteUrl || "").trim() || "(unknown website)";
  const fieldList = (Array.isArray(fields) && fields.length ? fields : DEFAULT_CANONICAL_FIELDS).join(", ");

  const sourceUrlsLine = includeSourceUrls
    ? "Also include location_source_urls with hq_source_urls and mfg_source_urls arrays containing the direct source URLs used for verification."
    : "";

  // Phase 2.12 — homepage context block. The pre-fetch helper extracts
  // title, meta description, and visible body text from the company's
  // homepage + /about + /about-us, then injects it here as the model's
  // primary highest-confidence source. Use this BEFORE web_search to
  // avoid the give-up-after-thin-results pattern (Eliza B / Flojos / Luna
  // Sandals / Kiwi Sandals). May be empty for JS-rendered SPAs or
  // Cloudflare-blocked sites — the prose research instructions still
  // apply when context is absent.
  const homepageContextBlock = homepageContext
    ? `Homepage Context (pre-fetched from the company's official site — your primary, highest-confidence source for tagline, HQ, products, industries, and feature/testimonial content):
${homepageContext}

Use the Homepage Context FIRST. Only run web_search / browse_page calls for facts you cannot verify from the context above (typically: manufacturing locations, third-party reviews, source URLs).

`
    : `Homepage Context: (pre-fetch failed or returned empty — proceed with web_search and browse_page on the official site as usual)

`;

  return `You are a precise company research specialist. Use web_search and browse_page tools efficiently. Verify facts with the company's official website plus one additional source where quickly accessible. Do not hallucinate. Focus only on the specified company. Time and tool budget are bounded — prefer emitting partial JSON over searching exhaustively.

For the Company: ${name} / ${url}
${homepageContextBlock}Fields to populate: ${fieldList}

Follow these baked-in rules for accuracy and formatting:
Be thorough, exact, verify sources using web_search and browse_page tools, and do not hallucinate. Focus only on the specified company.

Tagline: Provide the company's tagline, slogan, or motto. Format as described below.

HQ: Identify the HQ location from the company's official website (About / Contact pages or footer). If the official site is unclear, do one additional web_search to a credible source like LinkedIn, Crunchbase, or a recent press article. Use initials for state or province (e.g., City, ST, Country). Use USA, not US. No explanatory info — just the location string. If multiple HQ locations, separate with semicolons. Examples: "Linz am Rhein, Rhineland-Palatinate, Germany" or "Newport Beach, CA, USA". Do NOT include the label "HQ:" in the value — emit only the location content.

Manufacturing: List the company's known manufacturing locations from the official website's About / Press / Sustainability pages, supplemented if needed by one targeted web_search. Format each as City, State or Region, Country. Use initials for states or provinces. Use USA, not US. If only the country is known, that is acceptable. Output as a JSON array of strings, e.g. ["Görlitz, Germany", "Bernstadt, Germany", "Arouca, Portugal"]. If genuinely retailer/marketplace/reseller with no manufacturing, emit []. Do NOT include the label "Manufacturing:" in any value.

Industries: Provide 8-15 short noun phrases (1-3 words each) that read like real user search terms for what the company sells. Mix broad categories and specific sub-types. Examples for footwear (Birkenstock-style): "Cork Footbed Sandals", "Leather Sandals", "EVA Sandals", "Orthopedic Footwear", "Casual Slides", "Kids Sandals". Examples for snacks: "Beef Jerky", "Dried Meats", "Snack Sticks", "Hawaiian Foods". Use normalized, common-search-term language. Include meaningful distinctions ("organic", "leather", "stainless steel") but avoid narrative adjectives ("artisan", "premium", "hand-crafted"). Avoid generic umbrella terms ("Footwear", "Consumer Goods", "Food and Beverage", "Retail", "E-Commerce"). Output as a JSON array of strings. Do NOT prefix values with "Industries:".

Products: Provide 10-20 universal product categories or notable product lines, comma-separated. Prefer category-level terms that aid cross-company comparison and user search. Examples for a footwear brand: "Arizona sandals, Boston clogs, Mayari sandals, Gizeh sandals, Madrid sandals, EVA sandals, shearling clogs, mules, slides, boots". Examples for a snack brand: "beef jerky, dried meats, snack sticks, jerky bites, hawaiian-style snacks". Do NOT enumerate every SKU, every color/width variant, or every model number. Quality and breadth over exhaustiveness. Output as a single comma-separated string. Do NOT prefix with "Products:".

