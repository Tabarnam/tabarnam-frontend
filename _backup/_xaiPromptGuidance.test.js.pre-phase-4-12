test("Phase 2.6: prompt mandates JSON object emission (cannot output nothing)", () => {
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme",
    websiteUrl: "https://acme.example.com",
  });
  // The single most important Phase 2.6 instruction: model MUST emit JSON.
  // Phase 2.19.9 trimmed the redundant follow-up sentences. Phase 3.4
  // restructured: the strengthened mandate now lives at the TOP of the
  // prompt ("You MUST emit the final JSON object as your response") and
  // the redundant trailing "do not skip emission" sentence was deleted.
  // Lock down the core mandate using the Phase 3.4 wording.
  assert.ok(
    /You MUST emit (a|the final) JSON object/i.test(prompt),
    "prompt must explicitly mandate that the model emits a JSON object"
  );
  assert.ok(
    /Never finish with only tool calls/i.test(prompt) ||
    /Outputting nothing is NOT acceptable/i.test(prompt),
    "prompt must explicitly forbid finishing without text"
  );
  assert.ok(
    /do not skip emission/i.test(prompt) ||
    /Emitting an all-empty JSON object is preferable/i.test(prompt) ||
    /complete JSON object even if some fields are partial or unknown/i.test(prompt),
    "prompt must clarify that emission is mandatory even with empty fields"
  );
});

test("Phase 2.19.9: tool-budget enforcement now lives in code, not prompt prose", () => {
  // Phase 2.6 originally required a "MINIMUM EFFORT" prose block telling the
  // model to make at least 2 tool calls before giving up. Phase 2.19.9 drops
  // that block — the same protection is now enforced in code:
  //   - Tool cap (12 calls) in xaiLiveSearchStreaming
  //   - 45s grace window after cap is hit
  //   - Abort on post-cap tool call with 0 text (Phase 2.19.3)
  //   - Homepage-extraction fallback rescues tagline+HQ on canonical failure
  //     (Phase 2.19.7)
  //   - SSE-stall detection (60s silence → abort) in Phase 2.9.C
  // Per Grok-4's review: the redundant prompt blocks (TOOL BUDGET,
  // MINIMUM EFFORT, EMIT EARLY, NARROW BRANDS) were bloating the prompt to
  // 13K chars and making emission feel secondary to the model. Trimming them
  // and relying on code-level enforcement is the cleaner architecture.
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme",
    websiteUrl: "https://acme.example.com",
  });
  // The trimmed prompt should NOT contain the verbose blocks anymore.
  assert.ok(!/MINIMUM EFFORT/i.test(prompt), "MINIMUM EFFORT block should be removed");
  assert.ok(!/TOOL BUDGET — read carefully/i.test(prompt), "TOOL BUDGET block should be removed");
  assert.ok(!/EMIT EARLY/i.test(prompt), "EMIT EARLY prose block should be removed");
  // But the JSON-emission mandate must remain (locked in the test above).
});
