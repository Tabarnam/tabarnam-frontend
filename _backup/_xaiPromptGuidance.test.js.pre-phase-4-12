test("Phase 4.2: buildCanonicalImportPrompt includes unconditional effort floor + per-field always-search anchors", () => {
  // Phase 4.2 — Grok-reviewed prompt rewrite to fix the 0-tool-call
  // failure pattern observed in Phase 4.1 production logs (Char-Broil
  // and Char-Griller both emitted JSON in <18s with tool_calls: 0,
  // empty manufacturing_locations, empty product_keywords). Root cause:
  // Phase 4.1's effort floor had an escape clause ("unless Homepage
  // Context covers EVERY requested field") that grok-4.3 interpreted
  // permissively. Fix: make the floor UNCONDITIONAL; Homepage Context
  // does NOT count toward it; explicit failure-mode framing.
  //
  // Per-field rules strengthened:
  //   - Manufacturing: must verify even when Homepage Context mentions
  //     a country
  //   - Products: ALWAYS browse /products /shop /collections; never rely
  //     solely on Homepage Context
  //   - Reviews: ALWAYS perform at least 1 web_search; Homepage Context
  //     never contains third-party reviews
  //
  // Also removed the Phase 4.1 "highest-confidence source — trust it
  // directly and do NOT re-verify" sentence — it was contributing to the
  // satisfice pattern by signaling the homepage was sufficient.
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme Corp",
    websiteUrl: "https://acme.example",
    homepageContext: "Title: Acme Corp\nAbout: makers of widgets",
  });

  // ── (a) Top emission mandate (carries from Phase 4.1, unchanged) ─────────
  assert.ok(
    /you MUST emit the final JSON object as your response/i.test(prompt),
    "prompt must include 'you MUST emit the final JSON object as your response'"
  );
  assert.ok(
    /never finish with only tool calls and zero text/i.test(prompt),
    "prompt must include 'never finish with only tool calls and zero text'"
  );
  assert.ok(
    /that is a critical failure mode/i.test(prompt),
    "prompt must include 'that is a critical failure mode'"
  );
  assert.ok(
    /complete JSON object even if some fields are partial or unknown/i.test(prompt),
    "prompt must include 'complete JSON object... partial or unknown'"
  );

  // ── (b) Phase 4.2 UNCONDITIONAL effort floor — the headline change ──────
  assert.ok(
    /You MUST execute a minimum of 5 tool calls \(web_search or browse_page\) BEFORE you are allowed to emit your final JSON/i.test(prompt),
    "prompt must contain the Phase 4.2 UNCONDITIONAL effort floor ('MUST execute a minimum of 5 tool calls BEFORE')"
  );
  assert.ok(
    /The Homepage Context block does NOT count toward this minimum/i.test(prompt),
    "prompt must explicitly state Homepage Context does NOT count toward the floor"
  );
  assert.ok(
    /required to perform real searches even when some fields appear in the homepage text/i.test(prompt),
    "prompt must mandate real searches even when homepage has relevant text"
  );

  // ── (c) Per-field always-search reinforcement at the top ────────────────
  assert.ok(
    /You MUST search for manufacturing_locations, third-party reviews, and specific named product lines/i.test(prompt),
    "prompt must include the top-level 'MUST search for manufacturing, reviews, named product lines' mandate"
  );
  assert.ok(
    /almost never fully covered by the homepage/i.test(prompt),
    "prompt must include 'almost never fully covered by the homepage' rationale"
  );

  // ── (d) Failure-mode framing — 0-tool-calls is failure ──────────────────
  assert.ok(
    /Emitting JSON with 0 tool calls is a failure/i.test(prompt),
    "prompt must explicitly label 0-tool-call emission as a failure"
  );
  assert.ok(
    /Emitting with fewer than 3 tool calls and ANY empty manufacturing_locations or product_keywords field is also a failure/i.test(prompt),
    "prompt must label <3-tool-call emission with empty manufacturing/products as a failure"
  );

  // ── (e) Tool budget + numerical deadline (carried over) ─────────────────
  assert.ok(
    /tool budget:\s*up to 18 web_search/i.test(prompt),
    "prompt must include 'tool budget: up to 18 web_search'"
  );
  assert.ok(
    /After your 12th tool call you MUST emit within the next 2 calls at latest/i.test(prompt),
    "prompt must contain the numerical-deadline emission language"
  );
  assert.ok(
    /Partial but researched data is strongly preferred to early emission with missing fields/i.test(prompt),
    "prompt must contain the Phase 4.2 'partial but researched data preferred' language"
  );

  // ── (f) Phase 4.2 Manufacturing — must verify even when context mentions ─
  assert.ok(
    /Before emitting manufacturing_locations \(including \[\] or any country\), you MUST perform at least 2 targeted web_search calls/i.test(prompt),
    "prompt must contain Phase 4.2 Manufacturing 'MUST perform at least 2 targeted searches' mandate"
  );
  assert.ok(
    /Even if the Homepage Context mentions a country, you MUST verify it with at least 1 search/i.test(prompt),
    "prompt must contain Phase 4.2 Manufacturing 'verify even when context mentions country' mandate"
  );
  assert.ok(
    /\[Brand\] manufactured in/i.test(prompt) && /\[Brand\] Wikipedia/i.test(prompt),
    "prompt must contain Phase 4.2 Manufacturing example search patterns"
  );
  assert.ok(
    /parent 10-K filings/i.test(prompt),
    "prompt must contain 'parent 10-K filings' guidance"
  );

  // ── (f.2) Phase 4.3 Manufacturing — site-search + PDP fallback escalation ─
  // After 2 brand-level searches, model must try site:[brand-domain]
  // "Made in" — catches small-brand PDP-only disclosures (Cave Tools case).
  assert.ok(
    /site:\[brand-domain\]\s+"Made in"\s+OR\s+"manufactured in"\s+OR\s+"made in USA"/i.test(prompt),
    "Phase 4.3 — Manufacturing rule must contain the site:[brand-domain] escalation query"
  );
  assert.ok(
    /browse one product-detail page \(e\.g\. \/products\/\[first-product-slug\]\)/i.test(prompt),
    "Phase 4.3 — Manufacturing rule must contain the PDP fallback ('/products/[first-product-slug]')"
  );
  assert.ok(
    /Made in \[country\]" labels printed on the product page/i.test(prompt),
    "Phase 4.3 — Manufacturing rule must mention 'Made in [country]' product-page labels"
  );

  // ── (g) Phase 4.2 / 4.3 Products — ALWAYS browse + 150 ceiling + anti-pad ─
  assert.ok(
    /ALWAYS browse the brand's \/products, \/shop, or \/collections page before emitting product_keywords/i.test(prompt),
    "prompt must contain the Phase 4.2 Products 'ALWAYS browse /products /shop /collections' mandate"
  );
  assert.ok(
    /Never rely solely on the Homepage Context for product_keywords/i.test(prompt),
    "prompt must contain Phase 4.2 Products 'never rely solely on Homepage Context' mandate"
  );
  assert.ok(
    /Coyote Pellet Grill/.test(prompt) && /Duomo Pizza Oven/.test(prompt),
    "prompt must retain the named-product-lines examples (Coyote Pellet Grill, Duomo Pizza Oven)"
  );
  // Phase 4.3 ceiling raise (5-12 → up to 150) + anti-padding mandate
  assert.ok(
    /up to 150(?:\s+total)?\s+entries/i.test(prompt),
    "Phase 4.3 — Products rule must contain 'up to 150 entries' ceiling"
  );
  // Phase 4.7 rewrote the pagination instruction with more specifics
  // ("browse pages 2 and 3"). Accept either Phase 4.3 or Phase 4.7 wording.
  assert.ok(
    /Browse paginated catalog pages if needed/i.test(prompt) ||
    /If pagination exists.*browse pages 2 and 3/i.test(prompt),
    "Products rule must instruct paginated catalog browsing (Phase 4.3 or 4.7)"
  );
  assert.ok(
    /do not fabricate, do not pad with generic terms, do not invent products/i.test(prompt),
    "Phase 4.3 — Products rule must contain the anti-padding triple-negation"
  );
  assert.ok(
    /A smaller accurate list is always better than a padded list/i.test(prompt),
    "Phase 4.3 — Products rule must contain the 'smaller accurate list is always better' anchor"
  );

  // ── (h) Phase 4.2 Reviews — ALWAYS perform at least 1 search ────────────
  assert.ok(
    /ALWAYS perform at least 1 web_search for third-party reviews before emitting/i.test(prompt),
    "prompt must contain Phase 4.2 Reviews 'ALWAYS perform at least 1 web_search' mandate"
  );
  assert.ok(
    /The Homepage Context block never contains third-party reviews/i.test(prompt),
    "prompt must state 'Homepage Context never contains third-party reviews'"
  );

  // ── (i) Anti-regression — Phase 4.1 escape clause must be GONE ──────────
  assert.ok(
    !/unless the Homepage Context block above already contains verifiable data for EVERY requested field/.test(prompt),
    "Phase 4.1 escape clause 'unless Homepage Context contains EVERY field' must be removed (was the satisfice loophole)"
  );
  // Phase 4.1 had a "trust it directly and do NOT re-verify" sentence that
  // contributed to the satisfice pattern. Phase 4.2 removes it — the new
  // anti-satisfice framing supersedes it.
  assert.ok(
    !/Homepage Context block is your highest-confidence source[^.]*trust it directly/i.test(prompt),
    "Phase 4.1 'highest-confidence source — trust it directly and do NOT re-verify' sentence must be removed (contributed to satisfice)"
  );
  // Anti-regression — unreconciled "verify EVERY field" wording (also stays out)
  assert.ok(
    !/until you have verified data for EVERY requested field/.test(prompt),
    "prompt must NOT contain the unreconciled emission language that conflicts with homepage-direct-emit"
  );
});

