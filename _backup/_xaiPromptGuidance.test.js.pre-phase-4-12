test("_xaiLiveSearch source declares response_format parameter on both functions", () => {
  // Hard guarantee that Phase 1's response_format passthrough is present.
  // If this fails, the single-call worker (Phase 2) cannot enforce json_schema.
  const fs = require("node:fs");
  const path = require("node:path");
  const src = fs.readFileSync(path.join(__dirname, "_xaiLiveSearch.js"), "utf8");
  // Both function signatures must declare the parameter.
  const matches = src.match(/response_format,\s*\/\//g) || [];
  assert.ok(matches.length >= 2, "response_format must be declared on both xaiLiveSearch and xaiLiveSearchStreaming");
  // Both payload builders must spread response_format conditionally.
  const passthroughMatches = src.match(/response_format && typeof response_format === "object" \? \{ response_format \}/g) || [];
  assert.ok(passthroughMatches.length >= 2, "response_format must flow into both payload builders");
});

// ── Phase 2.6 — mandatory emission + minimum tool-call floor ────────────────
//
// Replicates fixes for the Eliza B failure (model emitted no text after 1
// tool call). The prompt now MUST instruct the model that emitting nothing
// is unacceptable, AND require a minimum of 2 tool calls before deciding
// the company has no findable data.

test("Phase 4.11: PROMPT_GUIDANCE_VERSION is 9.7.0-products-categories-mandate", () => {
  // Phase 4.11 — Grok-4 approved 3-change combination to fix the 17x
  // product depth variance observed in the 2026-05-13 9-company batch
  // (Eloquii 12 items / 185 chars; Evereve 85+ items / 2296 chars; same
  // prompt, same model, same reasoning.effort=high, same XAI_CONCURRENCY=1).
  //
  // Root cause: Phase 4.7's "Prefer specific named product lines over
  // generic categories" rule BIASED the model AWAY from category labels.
  // When a brand's catalog shows category cards (Eloquii, Torrid, Jockey),
  // the rule made the model skip them, producing 12-item maxes.
  //
  // Three changes:
  //   1. Products rule rewritten: "Include BOTH named lines AND categories"
  //      — the richest output mixes them (matches grok.com Expert style)
  //   2. Multi-page sub-page browsing for category-card brands — browse
  //      top 2-3 visible category/collection sub-pages
  //   3. product_keywords 5-entry floor in CRITICAL RULE block — explicit
  //      minimum, categories valid as fillers (no fabrication)
  assert.match(
    PROMPT_GUIDANCE_VERSION,
    /^9\.7\.0-products-categories-mandate/,
    "PROMPT_GUIDANCE_VERSION must be 9.7.0-products-categories-mandate for Phase 4.11"
  );
});

test("Phase 4.7: buildCanonicalImportPrompt contains per-field minimums + supply-chain + brand-prefix + multi-collection anchors", () => {
  // Phase 4.7 — Grok-4-recommended fixes for grok-4.3's 7-9 tool-call
  // satisficing pattern. Five distinct prompt additions:
  //
  //   1. "Per-field minimum research requirements (binding)" block lists
  //      explicit minimums (HQ 1, manufacturing 2, reviews 1) separate
  //      from the overall 5-call floor.
  //   2. Supply-chain investigation language ("Made in USA" on packaging
  //      is often marketing for assembly/import; investigate parent /
  //      trade press / supplier list).
  //   3. Multi-country emission mandate (emit ALL primary + secondary
  //      manufacturing/sourcing countries when evidence shows multiple).
  //   4. Brand-prefix mandate in Products (mirror the brand's naming
  //      convention — "Grillaholics Stuffed Burger Press" not
  //      "STUFFED BURGER PRESS").
  //   5. Multi-collection browsing in Products (browse pages 2-3 of
  //      paginated catalogs + separate top-level /collections pages —
  //      not just first collection).
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme Corp",
    websiteUrl: "https://acme.example",
    homepageContext: "",
  });

  // (1) Per-field minimum research requirements block
  assert.ok(
    /Per-field minimum research requirements \(binding\)/i.test(prompt),
    "prompt must include 'Per-field minimum research requirements (binding)' block heading"
  );
  assert.ok(
    /headquarters_location: minimum 1 dedicated web_search/i.test(prompt),
    "prompt must specify HQ minimum 1 web_search"
  );
  assert.ok(
    /manufacturing_locations: minimum 2 targeted web_search calls AND the full escalation ladder/i.test(prompt),
    "prompt must specify manufacturing minimum 2 web_searches + escalation"
  );
  assert.ok(
    /reviews: minimum 1 dedicated web_search/i.test(prompt),
