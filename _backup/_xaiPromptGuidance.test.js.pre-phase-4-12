  // the same protection in fewer tokens.
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme",
    websiteUrl: "https://acme.example.com",
  });
  assert.ok(
    /Never finish with only tool calls/i.test(prompt) ||
    /Never complete a response with only tool calls and zero text/i.test(prompt),
    "anti-give-up clause must be present (trimmed or verbose form)"
  );
  // The "You cannot give up early" + "If your first 1-2 web_search calls"
  // sentences are dropped; their intent is captured by "do not skip emission"
  // and the Phase 2.19.7 homepage-extraction fallback (which rescues
  // tagline+HQ when the canonical model gives up).
});

