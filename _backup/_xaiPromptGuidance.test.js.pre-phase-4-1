// ── parseCanonicalJson ──────────────────────────────────────────────────────

test("parseCanonicalJson parses a bare object", () => {
  assert.deepEqual(parseCanonicalJson('{"tagline":"hi"}'), { tagline: "hi" });
});

test("parseCanonicalJson strips ```json code fences", () => {
  const text = "```json\n{\"tagline\":\"hi\"}\n```";
  assert.deepEqual(parseCanonicalJson(text), { tagline: "hi" });
});

test("parseCanonicalJson strips bare ``` code fences", () => {
  const text = "```\n{\"tagline\":\"hi\"}\n```";
  assert.deepEqual(parseCanonicalJson(text), { tagline: "hi" });
});

test("parseCanonicalJson tolerates leading/trailing whitespace", () => {
  assert.deepEqual(parseCanonicalJson('  \n  {"tagline":"hi"}  \n  '), { tagline: "hi" });
});

test("parseCanonicalJson tolerates array-of-1 wrapping (defensive)", () => {
  assert.deepEqual(parseCanonicalJson('[{"tagline":"hi"}]'), { tagline: "hi" });
});

test("parseCanonicalJson returns null on unparseable input", () => {
  assert.equal(parseCanonicalJson("not json at all"), null);
  assert.equal(parseCanonicalJson(""), null);
  assert.equal(parseCanonicalJson(null), null);
  assert.equal(parseCanonicalJson(undefined), null);
});

test("parseCanonicalJson returns null when content is a primitive (not object)", () => {
  assert.equal(parseCanonicalJson('"just a string"'), null);
  assert.equal(parseCanonicalJson("42"), null);
});

test("parseCanonicalJson handles model preamble + JSON object", () => {
  const text = "Sure, here is the JSON:\n\n{\"tagline\":\"hi\",\"red_flag\":false}\n\nLet me know if you need more.";
  assert.deepEqual(parseCanonicalJson(text), { tagline: "hi", red_flag: false });
});

// ── _xaiLiveSearch response_format passthrough ──────────────────────────────

test("_xaiLiveSearch.js exports xaiLiveSearch and xaiLiveSearchStreaming", () => {
  const ls = require("./_xaiLiveSearch");
  assert.equal(typeof ls.xaiLiveSearch, "function");
  assert.equal(typeof ls.xaiLiveSearchStreaming, "function");
});

test("_xaiLiveSearch source declares response_format parameter on both functions", () => {
  // Hard guarantee that Phase 1's response_format passthrough is present.
  // If this fails, the single-call worker (Phase 2) cannot enforce json_schema.
  const fs = require("node:fs");
  const path = require("node:path");
  const src = fs.readFileSync(path.join(__dirname, "_xaiLiveSearch.js"), "utf8");
  // Both function signatures must declare the parameter.
  const matches = src.match(/response_format,\s*\/\//g) || [];
  assert.ok(matches.length >= 2, "response_format must be declared on both xaiLiveSearch and xaiLiveSearchStreaming");
  // Both payload builders must spread response_format conditionally.
  const passthroughMatches = src.match(/response_format && typeof response_format === "object" \? \{ response_format \}/g) || [];
  assert.ok(passthroughMatches.length >= 2, "response_format must flow into both payload builders");
});

// ── Phase 2.6 — mandatory emission + minimum tool-call floor ────────────────
//
// Replicates fixes for the Eliza B failure (model emitted no text after 1
// tool call). The prompt now MUST instruct the model that emitting nothing
// is unacceptable, AND require a minimum of 2 tool calls before deciding
// the company has no findable data.

test("Phase 3.6: PROMPT_GUIDANCE_VERSION is 9.1.0-stricter-emission-and-ceilings", () => {
  // Phase 3.6 — minor version bump from 9.0.0 to 9.1.0 marks the stricter
  // emission language ("after 12th tool call you MUST emit within 2") and
  // tightened per-field ceilings (industries 3-8, products 5-12). Goal:
  // reduce the ~10-15% cap-exhaustion failure rate on rich-product brands
  // (Fleischmann's, King Arthur, Adams, Camp Chef pattern).
  assert.match(
    PROMPT_GUIDANCE_VERSION,
    /^9\.1\.0-stricter-emission-and-ceilings/,
    "PROMPT_GUIDANCE_VERSION must be 9.1.0-stricter-emission-and-ceilings for Phase 3.6"
  );
});

test("Phase 3.4: buildCanonicalImportPrompt includes emission mandate + 18-tool budget block at top", () => {
  // Phase 3.4 inserts two paragraphs at the top of the SYSTEM block
  // (between homepageContextBlock and Fields to populate). Grok-4 reviewed
  // both paragraphs across two rounds; this test locks down the final
  // strengthened wording so accidental reversion is caught.
  const prompt = buildCanonicalImportPrompt({
    companyName: "Acme Corp",
    websiteUrl: "https://acme.example",
    homepageContext: "Title: Acme Corp\nAbout: makers of widgets",
  });
  // (a) Strengthened emission mandate (Grok revision 1)
  assert.ok(
    /you MUST emit the final JSON object as your response/i.test(prompt),
    "prompt must include 'you MUST emit the final JSON object as your response' (Grok revision 1)"
  );
  assert.ok(
    /never finish with only tool calls and zero text/i.test(prompt),
    "prompt must include 'never finish with only tool calls and zero text'"
  );
  assert.ok(
    /critical failure mode we have observed and must avoid/i.test(prompt),
    "prompt must include the Grok-tightened 'we have observed and must avoid' phrase"
  );
  assert.ok(
    /complete JSON object even if some fields are partial or unknown/i.test(prompt),
    "prompt must include 'complete JSON object... partial or unknown'"
  );
  // (b) Budget
  assert.ok(
    /tool budget:\s*up to 18 web_search/i.test(prompt),
    "prompt must include 'tool budget: up to 18 web_search'"
  );
  // (c) Highest-confidence source (Grok revision 2)
  assert.ok(
    /Homepage Context block is your highest-confidence source[^.]*trust it directly/i.test(prompt),
    "prompt must include the 'highest-confidence source — trust it directly' sentence (Grok revision 2)"
  );
  // (d) Phase 3.6 — stricter numerical deadline for emission. Replaces
  // Phase 3.4's softer "continue until you have data" wording with a
  // hard "after your 12th tool call you MUST emit within the next 2".
  assert.ok(
    /After your 12th tool call you MUST emit within the next 2 calls at latest/i.test(prompt),
    "prompt must contain the Phase 3.6 numerical-deadline emission language"
  );
  assert.ok(
    /Partial data is REQUIRED and preferred to zero text/i.test(prompt),
    "prompt must contain the Phase 3.6 'partial data is REQUIRED' language"
  );
  // Anti-regression — must NOT contain the unreconciled "verify EVERY field"
  // wording that would conflict with the homepage-direct-emit optimization.
  assert.ok(
    !/until you have verified data for EVERY requested field/.test(prompt),
    "prompt must NOT contain the unreconciled emission language that conflicts with homepage-direct-emit"
  );
  // Phase 3.6 — per-field ceilings block must be present.
  assert.ok(
    /Per-field ceilings \(strict\)/i.test(prompt),
    "prompt must contain the Phase 3.6 per-field ceilings block header"
  );
  assert.ok(
    /Industries: exactly 5-8/i.test(prompt),
    "prompt must contain the Phase 3.6 'Industries: exactly 5-8' ceiling"
  );
  assert.ok(
