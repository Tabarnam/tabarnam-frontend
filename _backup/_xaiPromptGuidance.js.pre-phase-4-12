  "reviews",
];

/**
 * Build the canonical company-research prompt — modelled on the grok.com v1.1
 * prompt admin uses for manual cleanup, with output framed as JSON.
 *
 * Per-field rules are kept verbatim from the working grok.com prompt — they've
 * been refined in production. Only the trailing output-shape framing changes
 * (JSON object instead of plaintext labels).
 *
 * @param {Object} opts
 * @param {string} opts.companyName
 * @param {string} opts.websiteUrl
 * @param {string[]} [opts.fields] - JSON-key names to populate. Defaults to
 *        the full DEFAULT_CANONICAL_FIELDS list.
 * @param {boolean} [opts.includeSourceUrls=true] - Ask the model to include
 *        location_source_urls inline (used by bulk imports for audit).
 * @returns {string} Prompt body suitable for /v1/responses.
 */
function buildCanonicalImportPrompt({
  companyName,
  websiteUrl,
  fields = DEFAULT_CANONICAL_FIELDS,
  includeSourceUrls = true,
  homepageContext = "",
} = {}) {
  const name = String(companyName || "").trim() || "(unknown company)";
  const url = String(websiteUrl || "").trim() || "(unknown website)";
  const fieldList = (Array.isArray(fields) && fields.length ? fields : DEFAULT_CANONICAL_FIELDS).join(", ");

  const sourceUrlsLine = includeSourceUrls
    ? "Also include location_source_urls with hq_source_urls and mfg_source_urls arrays containing the direct source URLs used for verification."
    : "";

  // Phase 2.12 — homepage context block. The pre-fetch helper extracts
  // title, meta description, and visible body text from the company's
  // homepage + /about + /about-us, then injects it here as the model's
  // primary highest-confidence source. Use this BEFORE web_search to
  // avoid the give-up-after-thin-results pattern (Eliza B / Flojos / Luna
  // Sandals / Kiwi Sandals). May be empty for JS-rendered SPAs or
  // Cloudflare-blocked sites — the prose research instructions still
  // apply when context is absent.
  const homepageContextBlock = homepageContext
    ? `Homepage Context (pre-fetched from the company's official site — your primary source for tagline, HQ, products, and industries):
${homepageContext}

Emit tagline and HQ directly from this context if visible — do NOT run verification searches for facts the homepage already provides. Spend tool calls on data NOT in the context: manufacturing locations, third-party reviews, and source URLs.

`
    : `Homepage Context: (pre-fetch failed or returned empty — proceed with web_search and browse_page on the official site as usual)

`;

  return `You are a precise company research specialist. Use web_search and browse_page tools efficiently. Do not fabricate or hallucinate. Focus only on the specified company.

For the Company: ${name} / ${url}
${homepageContextBlock}You MUST emit the final JSON object as your response. Never finish with only tool calls and zero text — that is a critical failure mode. Always emit a complete JSON object even if some fields are partial or unknown.

CRITICAL RULE — EMPTY VALUES ONLY: When you cannot determine a value after required searches, emit the type-correct empty value ONLY:
- tagline / headquarters_location: ""
- manufacturing_locations / industries / reviews: []
- product_keywords: ""
- location_source_urls: {"hq_source_urls": [], "mfg_source_urls": []}
Never emit explanations, parentheticals, "no specific...", "identified in sources", "likely...", "common for category", or ANY rationale text inside any field value. Emitting filler text instead of empty is a critical failure that breaks downstream systems. Examples of forbidden values: "(no specific city identified in sources)", "(U.S. brand under X)", "(likely overseas production common for category)". If you don't know, emit "" or [] — never a sentence explaining why.

Tool-call effort floor: You MUST execute a minimum of 5 tool calls (web_search or browse_page) BEFORE you are allowed to emit your final JSON. The Homepage Context block does NOT count toward this minimum — it is only background information. You are required to perform real searches even when some fields appear in the homepage text.

You MUST search for manufacturing_locations, third-party reviews, and specific named product lines. These fields are almost never fully covered by the homepage.

Emitting JSON with 0 tool calls is a failure. Emitting with fewer than 3 tool calls and ANY empty manufacturing_locations or product_keywords field is also a failure.

Tool budget: up to 18 web_search + browse_page calls. After your 12th tool call you MUST emit within the next 2 calls at latest. Partial but researched data is strongly preferred to early emission with missing fields.

Per-field minimum research requirements (binding):
- headquarters_location: minimum 1 dedicated web_search (official site + one external source like LinkedIn, Crunchbase, or Wikipedia if the official site is unclear).
- manufacturing_locations: minimum 2 targeted web_search calls AND the full escalation ladder (brand-level → site:domain → one PDP) before emitting [].
- reviews: minimum 1 dedicated web_search before emitting [].
These minima are SEPARATE from the overall 5-call floor. You MUST meet the per-field minimum for each requested field even if you have already reached the overall floor. Skipping these is a critical failure — small brands often have findable HQ + manufacturing data that requires dedicated searches beyond homepage extraction.

product_keywords MUST contain at least 5 entries unless the brand has genuinely fewer than 5 visible products or categories across the homepage and top-level shop/collection pages. If after required browsing you still have fewer than 5 entries, emit the visible CATEGORY LABELS to reach the floor — categories are valid product_keywords entries (see Products rule). Never fabricate entries. This floor prevents the observed "12-item-max" pattern on category-card brands like Eloquii, Torrid, and Jockey where the homepage carousel only exposed 12 collection names and the model emitted nothing more.

Fields to populate: ${fieldList}

Per-field rules:

Tagline: Provide the company's tagline, slogan, or motto. Format as described below.

HQ: Identify the HQ location from the company's official website (About / Contact pages or footer). If the official site is unclear, do one additional web_search to a credible source like LinkedIn, Crunchbase, or a recent press article. Use initials for state or province (e.g., City, ST, Country). Use USA, not US. No explanatory info — just the location string. If multiple HQ locations, separate with semicolons. Examples: "Linz am Rhein, Rhineland-Palatinate, Germany" or "Newport Beach, CA, USA". Do NOT include the label "HQ:" in the value — emit only the location content. If no verifiable HQ location is found after all required searches, emit exactly "" (empty string) — never any explanatory text, parenthetical rationale, or "no specific X identified" phrasing.

Manufacturing: Before emitting manufacturing_locations (including [] or any country), you MUST perform at least 2 targeted web_search calls. Even if the Homepage Context mentions a country, you MUST verify it with at least 1 search before emitting that country. Effective queries: "[Brand] manufactured in", "[Brand] factory", "[Brand] made in China/Vietnam/Mexico/USA", "[Brand] Wikipedia", "[Parent company] supplier list", or "[Brand] sustainability report". Many brands disclose this only in parent 10-K filings, trade articles, or Wikipedia. If brand-level searches do not yield disclosure after 2 attempts, try a site-specific search: site:[brand-domain] "Made in" OR "manufactured in" OR "made in USA". If still not found, browse one product-detail page (e.g. /products/[first-product-slug]) and look for "Made in [country]" labels printed on the product page. Country-level granularity is acceptable. Only emit [] if you have genuinely searched (brand-level → site:domain → one PDP) and found no information. If no verifiable manufacturing location is found after all required searches, emit exactly [] (empty array) — never any explanatory text, parenthetical rationale, "no specific X identified", "likely overseas production", "common for category", or similar filler phrases inside the array.

List the company's known manufacturing locations. Many consumer brands DO NOT disclose manufacturing on their public-facing About/Press pages — for these, you MUST do additional searches before concluding "no manufacturing found." Search strategy (try in this order, up to 3 searches):
  1. Official website's About / Press / Sustainability / Supply Chain pages.
  2. If brand is part of a larger portfolio (e.g., Sanuk → Deckers Brands; Sperry → Wolverine Worldwide; Reef → Rockport; The North Face → VF Corporation), search the parent company's sustainability report, supplier list, or 10-K filing — manufacturing disclosures are often only at the parent-company level.
  3. Targeted web_search queries: "[Brand] manufacturing locations", "[Brand] supplier list", "[Brand] factory", "[Brand] made in [country]", "[Parent company] sustainability report".
  4. Industry sources: Fair Labor Association reports, WRAP-certified factories list, Footwear News / industry trade press.
Format each as City, State or Region, Country. Use initials for states or provinces. Use USA, not US. Country-level granularity IS ACCEPTABLE — "Vietnam" alone is valid if specific cities are not disclosed; do not omit a known country just because the city is missing. Output as a JSON array of strings, e.g. ["Görlitz, Germany", "Vietnam", "Hai Duong, Vietnam"]. If after the searches above you genuinely cannot find any manufacturing disclosure, emit [] — but only AFTER attempting the parent-company / supplier-list searches above. For retailer-curators that resell branded products from many suppliers (e.g., a Japanese-stationery curator selling notebooks, pens, and watercolors from multiple makers; a multi-brand boutique), list the supplier countries — country-level granularity is the goal here. Only emit [] if the company is a pure marketplace platform (e.g., Amazon, eBay) where listing supplier countries is genuinely not meaningful. Do NOT include the label "Manufacturing:" in any value.

Investigate the full supply chain. "Made in USA" on packaging or a single product page is often marketing for final assembly or import labeling — the actual manufacturing origin may be different. When multiple sources conflict or only partial disclosure exists, emit the most accurate primary manufacturing locations based on the weight of evidence across searches. Prefer verified importer/distributor records, parent-company supplier lists, or trade-press supply-chain reporting over single-product "Made in" labels when they conflict. When evidence shows multiple primary manufacturing or sourcing countries (e.g. premium lines in one country, accessories/imports in another), emit ALL of them. Do not emit [] if any verifiable locations were found, even if the picture is incomplete.

Industries: Provide 3-8 short noun phrases (1-3 words each) that read like real user search terms for what the company sells. Aim for 5-8 for diversified brands (multi-product); for narrow / single-product brands (e.g., a peanut-butter-only brand, a single-flavor jerky, a one-product startup), 3-5 entries is correct and sufficient — DO NOT keep searching to pad the list. Mix broad categories and specific sub-types where applicable. The Phase 3.6 ceiling for this field is 8, regardless of how many sub-categories the brand has. Examples for footwear (Birkenstock-style): "Cork Footbed Sandals", "Leather Sandals", "EVA Sandals", "Orthopedic Footwear", "Casual Slides", "Kids Sandals". Examples for snacks: "Beef Jerky", "Dried Meats", "Snack Sticks", "Hawaiian Foods". Examples for a single-product peanut butter brand: "Natural Peanut Butter", "Creamy Peanut Butter", "Crunchy Peanut Butter", "No-Stir Peanut Butter". Use normalized, common-search-term language. Include meaningful distinctions ("organic", "leather", "stainless steel") but avoid narrative adjectives ("artisan", "premium", "hand-crafted"). Avoid generic umbrella terms ("Footwear", "Consumer Goods", "Food and Beverage", "Retail", "E-Commerce"). Output as a JSON array of strings. Do NOT prefix values with "Industries:".

Products: Include BOTH specific named product lines AND product/collection categories. The richest, most useful output mixes them.
- When the catalog shows many named items inline or on product pages, list the named lines (with brand prefix when used) AND the surrounding category/collection labels.
- When the catalog is primarily category cards or landing pages without inline named products, list ALL visible category and collection labels.
- Never skip visible categories just because they appear "generic". Category labels provide essential structure for admin search and filtering.
- Always prefer exact visible text from the site over invented names.

ALWAYS browse the brand's /products, /shop, or /collections page before emitting product_keywords. Never rely solely on the Homepage Context for product_keywords — the homepage usually lists categories or hero products, not the full named product lines. If pagination exists (Next button, page numbers, "Load more"), browse pages 2 and 3 to capture more of the line-up.

For brands whose homepage or main shop page primarily shows category cards rather than inline named products, browse the top 2-3 visible category or collection pages (e.g. /collections/dresses, /shop/category, main nav links) to enumerate both category labels and any named items on those sub-pages. This directly addresses category-card structured sites (e.g. Eloquii, Torrid, Jockey style) and is well within your tool budget.

If multiple top-level collections exist (e.g. /collections/all, separate series pages, distinct category sub-pages), browse the additional collections too — do not stop at the first collection page. List BOTH every specific named product line AND every visible category/collection label, up to 150 total entries. Examples of named lines: "Coyote Pellet Grill", "Duomo Pizza Oven", "S-Series Gas Grills", "Kady Pants", "Veronica Legging", "Cloudmonster". Examples of category labels (valid entries): "Plus Size Dresses", "Sports Bras", "Yoga Pants", "Pellet Grills", "Pizza Ovens", "Work Tops". Include the brand name as a prefix when the brand uses one in its public product naming (e.g. "Grillaholics Stuffed Burger Press", "Schmidt Brothers Artisan Series"). Use naked names only when the brand sells unbranded SKUs or uses no brand prefix in its own catalog. When the brand has many named lines, list all of them ALONGSIDE the surrounding categories. When the brand has fewer named items but visible categories, list ALL the visible categories — do not fabricate, do not pad with generic terms, do not invent products to reach a higher count. A smaller accurate list is always better than a padded list. Output as a single comma-separated string. Do NOT prefix with "Products:".

Reviews: ALWAYS perform at least 1 web_search for third-party reviews before emitting. The Homepage Context block never contains third-party reviews. Find up to 5 unique reviews. If you already have 3+ solid reviews, emit IMMEDIATELY — do not keep searching for the last 2. Target mix: 3-4 third-party reviews (YouTube, credible magazines, blogs, X/Twitter) + 1-2 entries pulled from the company's own site (testimonials, press mentions, "as seen in" sections, FAQ highlights, mission statements, or customer feedback). For smaller brands with limited third-party coverage, the company's own site is a valid primary source — pull customer testimonials and feature highlights from there to reach 3 total entries. Do not include reviews from amazon.* or google.* domains. Do not include duplicate authors or duplicate URLs. You are NOT required to revisit each URL to confirm liveness — return URLs as you found them during search. Output as a JSON array of objects, each with EXACTLY these keys: source (publication or channel name, or e.g. "[Company] official site testimonials" for site-sourced entries), author (name, or "Verified customers" / "Multiple customers" for site-sourced entries), url (direct URL to the review/article/video — for site testimonials, link to the page where they appear, not the site root), title (exact title as published, or short descriptive label for site testimonials), date (any format including "Ongoing" for live testimonial pages), text (1-3 sentence excerpt or summary). If you find fewer than 5, return what you found. If genuinely no reviews or testimonials exist, emit []. Do NOT pad with fabricated entries.

${sourceUrlsLine}

Type-correct empty values (use these when a field can't be verified):
- tagline, headquarters_location, product_keywords → ""
- manufacturing_locations, industries, reviews → []
- location_source_urls → {"hq_source_urls": [], "mfg_source_urls": []}
- red_flag → false

Never use "" for an array field. Never omit any required field.

Do NOT include field labels (e.g. "HQ:", "Tagline:") inside JSON values — emit only the clean content. Example: headquarters_location should be "Newport Beach, CA, USA", not "HQ: Newport Beach, CA, USA".

Return ONLY a single JSON object with these property names: tagline, headquarters_location, manufacturing_locations, industries, product_keywords, reviews, location_source_urls (with hq_source_urls and mfg_source_urls), red_flag, social. No prose, no markdown, no extra text.`;
}

// ─── Phase 3.0 — Multi-call parallel canonical architecture ─────────────────
//
// Three focused prompt builders that split `buildCanonicalImportPrompt`'s work
// across 3 parallel `/v1/responses` calls. Each builder produces a much
// narrower prompt (only the per-field rules relevant to that call) but keeps
// the same SHARED PREFIX (system instructions + homepage context) and SHARED
// SUFFIX (emission mandate, empty-value rules, return-keys enumeration).
//
// Per Grok-4's review of cache efficiency: xAI's prefix cache matches on the
// contiguous prefix from the start of the prompt. By keeping the SHARED PREFIX
// byte-identical across all 3 calls (when called for the same company with
// the same conversation_id), we get a high cache-hit rate on roughly the
// first 70% of each prompt, discounted from $3/M to $0.75/M.
//
// The 3 calls cover:
//   - Call 1 (Core, 0 tools, 60s):    tagline, industries, product_keywords
//   - Call 2 (Locations, 5 tools, 90s): headquarters_location, manufacturing_locations, location_source_urls
//   - Call 3 (Reviews, 5 tools, 90s):  reviews
//
// Wired up in `runMultiCallCanonical` (see `_canonicalImport.js`) and gated
// behind XAI_MULTI_CALL_MODE=on env var.

/**
 * Shared prompt-scaffold helper — builds the parts of the prompt that are
 * identical across all 3 multi-call prompts. Used by buildCorePrompt,
 * buildLocationsPrompt, buildReviewsPrompt.
 *
 * @param {Object} opts
 * @param {string} opts.name — company name
 * @param {string} opts.url — website url
 * @param {string} opts.homepageContext — pre-fetched homepage text (may be "")
 * @param {string} opts.fieldsList — comma-separated field names being requested
 * @param {string} opts.perFieldRules — call-specific per-field rule block
 * @param {string} opts.emptyValueLines — call-specific type-correct empties
 * @param {string} opts.returnKeysLine — call-specific "Return ONLY ..." line
 * @returns {string} Full prompt body
 */
function _buildMultiCallScaffold({
  name,
  url,
  homepageContext,
  fieldsList,
  perFieldRules,
  emptyValueLines,
  returnKeysLine,
}) {
  const homepageContextBlock = homepageContext
    ? `Homepage Context (pre-fetched from the company's official site — your primary source):
${homepageContext}

Emit fields directly from this context if visible — do NOT run verification searches for facts the homepage already provides.

`
    : `Homepage Context: (pre-fetch failed or returned empty)

`;

  return `You are a precise company research specialist. Use web_search and browse_page tools efficiently. Do not fabricate or hallucinate. Focus only on the specified company.

For the Company: ${name} / ${url}
${homepageContextBlock}Fields to populate (THIS CALL ONLY): ${fieldsList}

Per-field rules:

${perFieldRules}

You MUST emit a JSON object as your final response. Never finish with only tool calls — that is a critical failure mode. If you cannot verify a field, emit the type-correct empty value rather than skip emission.

Type-correct empty values:
${emptyValueLines}

Never use "" for an array field. Do NOT include field labels (e.g. "HQ:", "Tagline:") inside JSON values — emit only the clean content.

${returnKeysLine}`;
}

/**
 * Phase 3.0 — Call 1 (Core) prompt: tagline + industries + product_keywords.
 *
 * Tools disabled in this call (handled by caller via maxToolCalls=0). The
 * homepage prefetch context is the primary source for these fields on most
 * brands (~80-85% hit rate per Grok-4's analysis). For thin-presence brands
 * where the prefetch is empty/poor, Call 1 emits empties and the fallback
 * may rescue tagline via Phase 2.19.7's tryHomepageExtractionFallback.
 */
function buildCorePrompt({ companyName, websiteUrl, homepageContext = "" } = {}) {
  const name = String(companyName || "").trim() || "(unknown company)";
  const url = String(websiteUrl || "").trim() || "(unknown website)";

  const perFieldRules = `Tagline: Provide the company's tagline, slogan, or motto if visible in the homepage context. If no clear tagline is present, emit "".

Industries: Provide 3-15 short noun phrases (1-3 words each) that read like real user search terms for what the company sells. Aim for 8-15 for diversified brands (multi-product); for narrow / single-product brands, 3-6 entries is correct and sufficient — DO NOT pad. Mix broad categories and specific sub-types. Examples for footwear: "Cork Footbed Sandals", "Leather Sandals". Examples for snacks: "Beef Jerky", "Dried Meats". Examples for single-product peanut butter: "Natural Peanut Butter", "Creamy Peanut Butter", "Crunchy Peanut Butter". Use normalized, common-search-term language. Avoid narrative adjectives and generic umbrella terms. Output as a JSON array of strings.

Products: Provide 3-20 universal product categories or notable product lines, comma-separated. Aim for 10-20 for diversified brands; for narrow / single-product brands, 3-8 is sufficient — DO NOT pad. Prefer category-level terms. Do NOT enumerate every SKU/variant/color. Output as a single comma-separated string.`;

  const emptyValueLines = `- tagline → ""
- product_keywords → ""
- industries → []`;

  const returnKeysLine = `Return ONLY a single JSON object with EXACTLY these property names: tagline (string), industries (array of strings), product_keywords (string). No prose, no markdown, no extra text.`;

  return _buildMultiCallScaffold({
    name,
    url,
    homepageContext,
    fieldsList: "tagline, industries, product_keywords",
    perFieldRules,
    emptyValueLines,
    returnKeysLine,
  });
}

