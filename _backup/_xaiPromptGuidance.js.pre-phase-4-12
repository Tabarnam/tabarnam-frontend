/**
 * Parse the canonical-import JSON response from xAI. Robust to:
 * - Markdown code fences (```json ... ```)
 * - Leading/trailing whitespace
 * - Bare object OR array-of-1 wrapping (defensive — schema strictness should
 *   prevent arrays, but tolerated for safety)
 *
 * Returns null on unparseable input rather than throwing, so the caller can
 * record a clean failure diagnostic instead of crashing the worker.
 */
function parseCanonicalJson(text) {
  if (text == null) return null;
  let s = typeof text === "string" ? text : String(text);
  s = s.trim();
  if (!s) return null;

  // Strip markdown code fences (```json ... ``` or ``` ... ```).
  const fence = s.match(/```(?:json)?\s*([\s\S]*?)```/i);
  if (fence) s = fence[1].trim();

  const firstBrace = s.indexOf("{");
  const firstBracket = s.indexOf("[");

  // Prefer bare object when it appears first (or is the only one).
  if (firstBrace >= 0 && (firstBracket < 0 || firstBrace < firstBracket)) {
    const lastBrace = s.lastIndexOf("}");
    if (lastBrace > firstBrace) {
      try {
        const obj = JSON.parse(s.slice(firstBrace, lastBrace + 1));
        return obj && typeof obj === "object" && !Array.isArray(obj) ? obj : null;
      } catch {
        return null;
      }
    }
  }

  // Tolerate array-wrapped output (defensive).
  if (firstBracket >= 0) {
    const lastBracket = s.lastIndexOf("]");
    if (lastBracket > firstBracket) {
      try {
        const arr = JSON.parse(s.slice(firstBracket, lastBracket + 1));
        if (Array.isArray(arr) && arr.length > 0) {
          const first = arr[0];
          return first && typeof first === "object" && !Array.isArray(first) ? first : null;
        }
      } catch {
        return null;
      }
    }
  }

  return null;
}

