  const emptyValueLines = `- reviews → []`;

  const returnKeysLine = `Return ONLY a single JSON object with EXACTLY one property: reviews (array of objects with keys source, author, url, title, date, text). No prose, no markdown, no extra text.`;

  return _buildMultiCallScaffold({
    name,
    url,
    homepageContext,
    fieldsList: "reviews",
    perFieldRules,
    emptyValueLines,
